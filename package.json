  "scripts": {
    "dev": "next dev --port 4444",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed-demo": "python3 scripts/seed_demo_vault.py --vault /tmp/setlist-demo-vault",
    "demo": "npm run seed-demo && echo '\\n→ Demo vault ready at /tmp/setlist-demo-vault\\n→ Start backend: SETLIST_VAULT=/tmp/setlist-demo-vault SETLIST_INTEGRATIONS_DIR=/tmp/none uvicorn main:app --port 4445 --reload\\n→ Start frontend: npm run dev'",
    "screenshot": "node scripts/screenshots.mjs"
  },
  "dependencies": {
