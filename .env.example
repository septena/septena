# Septena configuration — copy to .env.local (Next.js) and export in your
# shell for the Python backend. All values are optional; defaults are shown.

# ── Filesystem ──────────────────────────────────────────────────────────────
# Where Septena's data directory lives. Every section (Exercise,
# Nutrition, Habits, etc.) reads and writes YAML under here.
# SEPTENA_DATA_DIR=~/Documents/septena-data

# Read-only aggregated health data (Oura/Withings/HAE snapshots).
# SEPTENA_HEALTH_DIR=~/Documents/septena-data/Health

# Credentials/tokens for optional external services. Missing files mean
# that integration is simply skipped — the rest of the app still works.
# SEPTENA_INTEGRATIONS_DIR=~/.config/openclaw

# App-owned scratch space (caches, derived data).
# SEPTENA_CACHE_DIR=~/.config/septena

# ── Network ─────────────────────────────────────────────────────────────────
# Where the FastAPI backend is reachable from the Next.js dev server.
# SEPTENA_BACKEND_URL=http://127.0.0.1:7000

# Comma-separated hostnames allowed by Next.js in dev (for LAN/Tailscale
# access from other devices). Add your phone's hostname/IP here.
# SEPTENA_DEV_ORIGINS=localhost
